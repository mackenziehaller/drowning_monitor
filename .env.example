# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Custom Search API (get from https://developers.google.com/custom-search/v1/introduction)
GOOGLE_CSE_API_KEY=your_custom_search_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Database — SQLite (default) or Postgres
# For SQLite: leave DATABASE_URL unset or use: sqlite:///drowning_cases.db
# For Postgres: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///drowning_cases.db

# SMTP email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com
